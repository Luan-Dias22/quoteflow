rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email in ["luansold@gmail.com", "luansold@live.com"]));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidEmail(email) {
      return email is string && email.size() > 3 && email.size() < 255;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string && 
             data.companyName is string && data.companyName.size() > 0 &&
             data.email is string;
    }

    function isValidSupplier(data) {
      return hasOnlyAllowedFields(['userId', 'name', 'company', 'whatsapp', 'phone', 'email', 'address', 'observations', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.whatsapp is string && data.whatsapp.size() > 0 && data.whatsapp.size() < 30;
    }

    function isValidTool(data) {
      return hasOnlyAllowedFields(['userId', 'name', 'description', 'category', 'referencePrice', 'photoURL', 'contacts', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.category is string && data.category.size() > 0;
    }

    function isValidQuotation(data) {
      return hasOnlyAllowedFields(['userId', 'toolId', 'toolName', 'quantity', 'items', 'contacts', 'message', 'status', 'createdAt', 'updatedAt', 'pdfUrl', 'pdfName']) &&
             data.userId == request.auth.uid &&
             data.toolName is string &&
             (!('toolId' in data) || data.toolId is string) &&
             (!('quantity' in data) || data.quantity == null || data.quantity is number) &&
             (!('items' in data) || data.items is list) &&
             data.contacts is list &&
             data.message is string &&
             data.status in ['Enviado', 'Respondido', 'Negociando'] &&
             (!('pdfUrl' in data) || data.pdfUrl == null || data.pdfUrl is string) &&
             (!('pdfName' in data) || data.pdfName == null || data.pdfName is string);
    }

    function isValidLead(data) {
      return hasOnlyAllowedFields(['userId', 'name', 'email', 'phone', 'message', 'source', 'status', 'createdAt', 'updatedAt']) &&
             (data.userId == 'admin_demo' || (isAuthenticated() && data.userId == request.auth.uid)) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 500 &&
             data.email is string && data.email.size() < 500 &&
             data.phone is string && data.phone.size() < 50 &&
             data.message is string && data.message.size() < 5000 &&
             data.status in ['Novo Pedido', 'Pedido Lançado', 'Pedido Concluído'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // Suppliers
    match /suppliers/{supplierId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidSupplier(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidSupplier(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Tools
    match /tools/{toolId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidTool(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidTool(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Quotations
    match /quotations/{quotationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidQuotation(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidQuotation(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Leads
    match /leads/{leadId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.userId == 'admin_demo' || isAdmin());
      allow create: if isValidLead(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidLead(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
