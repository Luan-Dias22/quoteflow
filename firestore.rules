rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email in ["luansold@gmail.com", "luansold@live.com"] && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidEmail(email) {
      return email is string && email.size() > 3 && email.size() < 255;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string && 
             data.companyName is string && data.companyName.size() > 0 &&
             data.email is string;
    }

    function isValidSupplier(data) {
      return hasOnlyAllowedFields(['userId', 'name', 'company', 'whatsapp', 'phone', 'email', 'address', 'observations', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.whatsapp is string && data.whatsapp.size() > 0 && data.whatsapp.size() < 30;
    }

    function isValidTool(data) {
      return hasOnlyAllowedFields(['userId', 'name', 'description', 'category', 'referencePrice', 'photoURL', 'contacts', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.category is string && data.category.size() > 0;
    }

    function isValidQuotation(data) {
      return hasOnlyAllowedFields(['userId', 'toolId', 'toolName', 'quantity', 'contacts', 'message', 'status', 'createdAt', 'updatedAt', 'fileURL', 'fileName']) &&
             data.userId == request.auth.uid &&
             data.toolId is string &&
             data.toolName is string &&
             (data.quantity == null || data.quantity is number) &&
             data.contacts is list &&
             data.message is string &&
             data.status in ['Enviado', 'Respondido', 'Negociando'] &&
             (!('fileURL' in data) || data.fileURL is string) &&
             (!('fileName' in data) || data.fileName is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // Suppliers
    match /suppliers/{supplierId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidSupplier(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidSupplier(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Tools
    match /tools/{toolId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidTool(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidTool(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Quotations
    match /quotations/{quotationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidQuotation(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidQuotation(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
